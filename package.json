{
  "name": "dsap",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint . --ignore-pattern \"**/*.md\" --ignore-pattern \"docs/**\"",
    "lint:fix": "eslint . --ignore-pattern \"**/*.md\" --ignore-pattern \"docs/**\" --fix",
    "prepare": "husky",
    "audit": "audit-ci --high",
    "test:unit": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@lucide/vue": "^1.17.0",
    "@vueuse/core": "^14.3.0",
    "axios": "^1.17.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.35",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.8",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "audit-ci": "^7.1.0",
    "eslint": "^10.4.1",
    "eslint-plugin-format": "^2.0.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.7",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "vue-tsc": "^3.3.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,vue}": [
      "eslint --fix"
    ],
    "*.{json,md,yml}": [
      "eslint --fix"
    ]
  }
}
